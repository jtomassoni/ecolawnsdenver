# Copy to `.env` and fill in values. This repo uses only `.env` (not `.env.local`).

# --- App ---
PORT=3000
NODE_ENV=development

# --- Gmail (quote forms + CRM + invoices — all via SMTP) ---
# Use a Google App Password (Account → Security → 2FA → App passwords), not your normal login.
# Enable IMAP: Gmail → Settings → See all settings → Forwarding and POP/IMAP → Enable IMAP (for “Sync Gmail replies”).
EMAIL_USER=
EMAIL_APP_PASSWORD=

# Optional: nicer From line on CRM mail (must be this Gmail or a “Send mail as” alias).
# Example: EcoLawns Denver <ecolawnsdenver@gmail.com>
# CRM_FROM_EMAIL=

# Optional: separate Gmail only for CRM sends (otherwise uses EMAIL_USER above).
# CRM_SMTP_USER=
# CRM_SMTP_PASSWORD=

# Optional Reply-To (only if you need replies to a different address than From).
# CRM_REPLY_TO_EMAIL=

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# --- Staff CRM login ---
# Colon: CRM_USER=user:password
# Multiple: CRM_USERS=user1:pass1,user2:pass2
# JSON: CRM_USER={"username":"admin","password":"secret"}
CRM_USER=
# CRM_USERS=
# ADMIN_USER=
# ADMIN_USERS=

# JWT signing for CRM session (required for /crm login)
CRM_SESSION_SECRET=
# SESSION_SECRET=

# --- Supabase (optional) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Inbound email → CRM (optional) ---
# POST JSON to /api/crm/webhooks/inbound-email with Bearer secret (Zapier, etc.)
# CRM_INBOUND_WEBHOOK_SECRET=
# Same secret (or CRM_INBOUND_SYNC_SECRET) for cron: POST /api/crm/sync-inbox with Authorization: Bearer …
# CRM_INBOUND_SYNC_SECRET=

# --- Database (optional) ---
# DATABASE_URL=
